{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build: Debug (for GDB)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/build.py",
                "${input:deployPathInput}",
                "Debug"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build: Release (for distribution)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/build.py",
                "${input:deployPathInput}",
                "Release"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build: RelWithDebInfo ( with symbols)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/build.py",
                "${input:deployPathInput}",
                "RelWithDebInfo"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build: DebugASan (with AddressSanitizer)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/build.py",
                "${input:deployPathInput}",
                "DebugASan"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "deployPathInput",
            "type": "promptString",
            "description": "Enter the absolute path for mod deployment",
           "default": "/home/perrobjorn/.steam/steam/steamapps/common/Quake 2/rerelease/baseq2/"
        }
    ]
}