{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build: Debug (for GDB)",
            "type": "shell",
            "command": "${workspaceFolder}/build_mingw.sh",
            "args": [
                "${input:deployPathInput}",
                "Debug"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build: Release (for distribution)",
            "type": "shell",
            "command": "${workspaceFolder}/build_mingw.sh",
            "args": [
                "${input:deployPathInput}",
                "Release"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build: RelWithDebInfo (optimized with symbols)",
            "type": "shell",
            "command": "${workspaceFolder}/build_mingw.sh",
            "args": [
                "${input:deployPathInput}",
                "RelWithDebInfo"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build: DebugASan (with AddressSanitizer)",
            "type": "shell",
            "command": "${workspaceFolder}/build_mingw.sh",
            "args": [
                "${input:deployPathInput}",
                "DebugASan"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "deployPathInput",
            "type": "promptString",
            "description": "Enter the absolute path for mod deployment",
            "default": "/home/perrobjorn/q2rerelease/baseq2"
        }
    ]
}