{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure & Build for Linux",
            "type": "shell",
            "command": "rm -rf build && mkdir build && cd build && echo '--- Running CMake Configure ---' && cmake .. -DCMAKE_BUILD_TYPE=Release -G \"Unix Makefiles\" -DDEPLOY_DIRECTORY=\"${input:deployPathInput}\" && echo '--- Running Make ---' && make -j$(nproc) && echo '--- Running Make Install ---' && make install",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/bin/bash",
                    "args": [
                        "-c"
                    ]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "deployPathInput",
            "type": "promptString",
            "description": "Enter the absolute path for deployment (e.g., /path/to/Quake2/baseq2)",
            "default": "/home/perrobjorn/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common/Quake 2/rerelease/baseq2/"
        }
    ]
}