{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🎯 Attach to Quake 2 (MSVC Debug)",
            "type": "cppdbg",
            "request": "attach",
            "program": "/home/perrobjorn/.steam/steam/steamapps/common/Quake 2/rerelease/baseq2/game_x64.dll",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "sourceFileMap": {
                "/home/perrobjorn/Documents/Repo/Q2Remaster-Horde-Mod/": "${workspaceFolder}/"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set architecture",
                    "text": "set architecture i386:x86-64",
                    "ignoreFailures": true
                }
            ],
            "logging": {
                "engineLogging": false,
                "programOutput": true,
                "trace": false
            },
            "preLaunchTask": "🔧 Build: MSVC Debug"
        },
        {
            "name": "🔧 Attach to Quake 2 (MinGW Debug)",
            "type": "cppdbg",
            "request": "attach",
            "program": "/home/perrobjorn/.steam/steam/steamapps/common/Quake 2/rerelease/baseq2/game_x64.dll",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/x86_64-w64-mingw32-gdb",
            "sourceFileMap": {
                "/home/perrobjorn/Documents/Repo/Q2Remaster-Horde-Mod/": "${workspaceFolder}/"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "logging": { "engineLogging": false },
            "preLaunchTask": "📜 Build: Legacy MinGW Debug"
        }
    ]
}