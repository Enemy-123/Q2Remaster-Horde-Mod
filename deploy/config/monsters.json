  "//  MONSTER DEFINITIONS": "",
  "// ============================================================================ MONSTER DEFINITIONS": "",
  "// SCALING PARAMETERS:": "",
  "//   damage_scale  - Multiplier for ALL weapon damage (0.5 = half damage, 2.0 = double)": "",
  "//   health_scale  - Multiplier for base health (applied before wave scaling)": "",
  "//   armor_scale   - Multiplier for armor power": "",
  "//   speed_scale   - Multiplier for projectile speed (not commonly used)": "",
  "// 4": "",
  "// OVERRIDES (optional):": "",
  "//   weapon_damage - Override specific weapons only when needed": "",
  "//                   Example: {\"blaster\": 25} makes blaster 25 instead of global 10": "",
  "// ============================================================================ 4": "",

