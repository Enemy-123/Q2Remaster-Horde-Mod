{
  "// ============================================================================ 1": "",
  "//  GLOBAL WEAPON DAMAGE SYSTEM": "",
  "// ============================================================================ GLOBAL WEAPON DAMAGE SYSTEM": "",
  "// All monsters start with these base values, then apply their damage_scale": "",
  "// 1": "",
  "// Final Damage Formula:": "",
  "//   damage = global_base × damage_scale × wave_scaling × (1.5 if boss)": "",
  "// 2": "",
  "// TUNING GUIDE:": "",
  "//   - To make ALL monsters stronger: increase global_weapon_damage values": "",
  "//   - To make ONE monster stronger: increase that monster's damage_scale": "",
  "//   - To tune specific weapon: add weapon_damage override to that monster": "",
  "// 3": "",
  "// EXAMPLE:": "",
  "//   Tank at wave 1 with damage_scale 1.2:": "",
  "//     rocket damage = 50 (global) × 1.2 (scale) = 60": "",
  "//   Tank boss at wave 20:": "",
  "//     rocket damage = 50 × 1.2 × 1.8 (wave) × 1.5 (boss) = 162": "",
  "// ============================================================================ 2": "",
